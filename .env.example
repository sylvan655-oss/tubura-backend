# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://tubura_user:yourpassword@localhost:5432/tubura_db

# ── Security ───────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── Africa's Talking (SMS + USSD) ──────────────────────────
AT_USERNAME=sandbox                  # change to your AT username in prod
AT_API_KEY=your-africastalking-api-key
AT_SENDER_ID=TUBURA                  # registered short code / sender

# ── MTN MoMo (Collections) ────────────────────────────────
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=your-subscription-key
MTN_MOMO_API_USER=your-api-user-uuid
MTN_MOMO_API_KEY=your-api-key
MTN_MOMO_ENVIRONMENT=sandbox         # sandbox | production

# ── Airtel Money ──────────────────────────────────────────
AIRTEL_BASE_URL=https://openapi.airtel.africa
AIRTEL_CLIENT_ID=your-client-id
AIRTEL_CLIENT_SECRET=your-client-secret
AIRTEL_ENVIRONMENT=sandbox

# ── App ───────────────────────────────────────────────────
APP_ENV=development                  # development | production
FRONTEND_ORIGIN=http://localhost:3000

# ── Admin dashboard (/admin) ───────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-something-only-you-know
